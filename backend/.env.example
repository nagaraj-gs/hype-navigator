APP_NAME=Hype Navigator API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./hype_navigator.db
CORS_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080"]

# Optional: Reddit API credentials (recommended)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=HypeNavigator/1.0

# Optional: JSON arrays for social sources
REDDIT_SUBREDDITS=["CryptoCurrency","CryptoMarkets","SatoshiStreetBets","memecoins"]
TWITTER_QUERIES=["(doge OR pepe OR shib OR bonk OR wif) lang:en"]
TWITTER_ACCOUNTS_DB=./twscrape_accounts.db
SOCIAL_CSV_DIR=./backend/exports/social

# External market data API keys/endpoints
ETHERSCAN_API_KEY=
DEXSCREENER_SEARCH_URL=https://api.dexscreener.com/latest/dex/search
DEXSCREENER_PROFILE_URL=https://api.dexscreener.com/token-profiles/latest/v1
COINDESK_API_KEY=
COINGECKO_API_KEY=
